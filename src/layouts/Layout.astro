---
export interface Props {
    title: string;
    lang: string;
}
const { title, lang } = Astro.props;
import '../styles/global.css';
---
<!DOCTYPE html>
<html lang={lang}>
<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Frigidaire Outdoor Living � Dual Element Electric Grill. 700�F, IPX4 rated, UL certified. Free shipping, 2-year warranty.">
    <title>{title}</title>
    <link rel="icon" href="/wp-content/uploads/2025/12/cropped-FRIGIDAIRE-FAV-1-scaled-1-32x32.jpg" sizes="32x32">
    <link rel="preload" as="image" href="/wp-content/uploads/2025/12/FOL-first-banner-scaled-1.webp" type="image/webp">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">
    <style is:global>

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Gotham', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
            color: #333;
            line-height: 1.6;
        }

        .container {
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 20px;
        }

        /* Header */
        header {
            background: white;
            padding: 20px 0;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo {
            font-size: 24px;
            font-weight: 700;
            color: #333;
            text-decoration: none;
            letter-spacing: 2px;
        }

        nav ul {
            display: flex;
            list-style: none;
            gap: 30px;
            align-items: center;
        }

        nav a {
            text-decoration: none;
            color: #333;
            font-weight: 500;
            font-size: 14px;
            text-transform: uppercase;
            transition: color 0.3s;
        }

        nav a:hover {
            color: #DB4155;
        }

        .lang-switcher {
            font-weight: 600;
            cursor: pointer;
        }

        /* Hero Section */
        .hero {
            position: relative;
            height: 600px;
            overflow: hidden;
            background: url('/wp-content/uploads/2025/12/FOL-first-banner-scaled-1.webp') center/cover;
        }

        .hero::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(100deg, rgba(219, 65, 85, 0.85) 0%, rgba(219, 65, 85, 0.85) 42%, transparent 42%);
            z-index: 1;
        }

        .hero-content {
            position: relative;
            height: 100%;
            display: flex;
            align-items: center;
            z-index: 2;
        }

        .hero-text {
            position: relative;
            z-index: 2;
            max-width: 500px;
            padding: 60px;
            color: white;
        }

        .hero-text h1 {
            font-size: 48px;
            font-weight: 700;
            line-height: 1.2;
            margin-bottom: 20px;
        }

        .hero-text p {
            font-size: 18px;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .btn {
            display: inline-block;
            padding: 12px 30px;
            background: white;
            color: #DB4155;
            text-decoration: none;
            border-radius: 25px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn:hover {
            background: #f0f0f0;
            transform: translateY(-2px);
        }

        /* Welcome Section */
        .welcome {
            padding: 80px 0;
            background: white;
        }

        .welcome-content {
            display: grid;
            grid-template-columns: 1fr 1.5fr;
            gap: 60px;
            align-items: center;
        }

        .welcome h2 {
            font-size: 42px;
            font-weight: 700;
            margin-bottom: 10px;
            color: #333;
        }

        .welcome h2 span {
            color: #DB4155;
        }

        .welcome-text h3 {
            font-size: 20px;
            font-weight: 600;
            margin-bottom: 15px;
        }

        .welcome-text p {
            font-size: 16px;
            color: #666;
            line-height: 1.8;
        }

        /* Product Features */
        .product-features {
            padding: 80px 0 0 0;
            background: white;
        }

        .section-header {
            text-align: center;
            margin-bottom: 0;
        }

        .section-title {
            background: #DB4155;
            color: white;
            padding: 15px 30px;
            display: block;
            width: 100%;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .feature-grid {
            width: 100%;
        }

        .feature-content h3 {
            font-size: 36px;
            font-weight: 700;
            margin-bottom: 10px;
        }

        .feature-content h3 span {
            color: #DB4155;
        }

        .feature-content p {
            font-size: 16px;
            color: #666;
            line-height: 1.8;
        }

        .feature-image {
            text-align: center;
        }

        .feature-image img {
            max-width: 100%;
            height: auto;
        }

        .feature-video {
            width: 100%;
            text-align: center;
        }

        .feature-video video {
            width: 100%;
            height: auto;
            display: block;
        }

        /* Image Carousel */
        .image-carousel {
            padding: 60px 0;
            background: white;
        }

        .carousel-container {
            position: relative;
            max-width: 1300px;
            margin: 0 auto;
            padding: 0 60px;
        }

        .swiper {
            width: 100%;
            height: 100%;
        }

        .swiper-slide {
            text-align: center;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .swiper-slide img {
            width: 100%;
            height: auto;
            object-fit: cover;
        }

        .swiper-button-prev,
        .swiper-button-next {
            color: #DB4155 !important;
            width: 44px;
            height: 44px;
        }

        .swiper-button-prev:after,
        .swiper-button-next:after {
            font-size: 24px;
            font-weight: bold;
            color: #DB4155 !important;
        }
        
        .swiper-button-prev svg,
        .swiper-button-next svg {
            fill: #DB4155 !important;
        }

        /* Getting Started Tabs */
        .getting-started {
            padding: 0;
            background: white;
        }

        .getting-started-header {
            background: #DB4155;
            color: white;
            padding: 15px 30px;
            text-align: center;
            font-size: 18px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .tabs {
            display: flex;
            justify-content: center;
            gap: 60px;
            padding: 30px 0;
            background: white;
        }

        .tab {
            padding: 10px 0;
            background: transparent;
            border: none;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            color: #666;
            border-bottom: 3px solid transparent;
            transition: all 0.3s;
            text-transform: uppercase;
        }

        .tab.active {
            color: #DB4155;
            border-bottom-color: #DB4155;
        }

        .tab-content {
            display: none;
            background: white;
            padding: 60px 0;
        }

        .tab-content.active {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 60px;
            align-items: center;
        }

        #tab-2.active {
            grid-template-columns: 1fr 2fr;
            align-items: start;
        }

        .tab-text-box {
            background: #f5f5f5;
            padding: 40px;
            border-radius: 8px;
        }

        .tab-text h3 {
            font-size: 32px;
            font-weight: 700;
            margin-bottom: 20px;
        }

        .tab-text h3 span {
            color: #DB4155;
        }

        .tab-text ul {
            list-style: none;
        }

        .tab-text li {
            padding: 12px 0;
            padding-left: 30px;
            position: relative;
            font-size: 16px;
            color: #666;
        }

        .tab-text li:before {
            content: '?';
            position: absolute;
            left: 0;
            color: #DB4155;
            font-weight: bold;
        }

        /* Where to Buy */
        .where-to-buy {
            padding: 80px 0;
            background: white;
        }

        .retailers-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 30px;
            margin-top: 40px;
            min-height: 320px;
        }
        .retailer-skeleton {
            border-radius: 12px;
            overflow: hidden;
            background: #f0f0f0;
            animation: skeleton-pulse 1.4s ease-in-out infinite;
        }
        .retailer-skeleton-img  { height: 160px; background: #e0e0e0; }
        .retailer-skeleton-line { height: 18px; margin: 16px 20px 8px; background: #e0e0e0; border-radius: 4px; }
        .retailer-skeleton-line.short { width: 55%; height: 13px; margin-top: 0; }
        .retailer-skeleton-btn  { height: 40px; margin: 12px 20px 20px; background: #e0e0e0; border-radius: 99px; }
        @keyframes skeleton-pulse {
            0%, 100% { opacity: 1; } 50% { opacity: 0.5; }
        }

        .retailer-card {
            position: relative;
            display: block;
            text-decoration: none;
            color: inherit;
            border-radius: 10px;
            overflow: hidden;
            background: #f5f5f5;
            cursor: pointer;
            transition: background 0.35s ease;
        }

        .retailer-card:hover {
            background: var(--card-hover-bg);
        }

        .retailer-card-star {
            position: absolute;
            top: 14px;
            right: 21px;
            font-size: 30px;
            color: var(--star-color);
            z-index: 5;
            transition: opacity 0.25s ease, transform 0.25s ease;
        }

        .retailer-image-wrap {
            position: relative;
            height: 160px;
            background: transparent;
            transition: background 0.35s ease;
        }

        .retailer-card:hover .retailer-image-wrap {
            background: var(--card-hover-bg);
        }

        .retailer-image-wrap img {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            object-fit: cover;
            transition: opacity 0.35s ease;
        }

        .retailer-img-hover {
            opacity: 0;
        }

        .retailer-info {
            padding: 20px;
            background: transparent;
            display: flex;
            flex-direction: column;
        }


        .retailer-name {
            margin: 0;
            padding-left: 10px;
            font-size: 38px;
            font-weight: 600;
            color: var(--title-color);
            letter-spacing: -0.040em;
            transition: opacity 0.25s ease;
        }

        .retailer-availability {
            margin: 6px 0 28px;
            padding-left: 11px;
            font-size: 16px;
            color: var(--availability-color);
            margin-top: 1px;
            margin-bottom: 35px;
            transition: opacity 0.25s ease;
        }

        .retailer-btn {
            padding: 12px 0;
            width: 100%;
            max-width: 2600px;
            text-align: center;
            background: var(--button-bg);
            color: var(--button-text);
            border-radius: 999px;
            font-weight: 600;
            margin: 0 auto;
            transition: all 0.3s;
            display: block;
            text-decoration: none;
        }

        .retailer-card:hover .retailer-img-default {
            opacity: 0;
        }

        .retailer-card:hover .retailer-img-hover {
            opacity: 1;
        }

        .retailer-card:hover .retailer-name,
        .retailer-card:hover .retailer-availability {
            opacity: 0;
        }

        .retailer-card:hover .retailer-btn {
            background: transparent;
            border: 2px solid #ffffff;
            color: #ffffff;
        }

        /* Fix button visibility when hover bg is white */
        .retailer-card[style*="--card-hover-bg:#fff"]:hover .retailer-btn,
        .retailer-card[style*="--card-hover-bg: #fff"]:hover .retailer-btn {
            border: 2px solid #db4155;
            color: #db4155;
        }

        .retailer-card:hover .retailer-card-star {
            opacity: 0;
            transform: scale(0.8);
        }

        /* FAQ Section */
        .faq-section {
            padding: 80px 0;
            background: #f9f9f9;
        }

        .faq-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-top: 40px;
        }

        .faq-item {
            background: white;
            border: 1px solid #e0e0e0;
            border-radius: 8px;
            margin-bottom: 12px;
            overflow: hidden;
        }

        .faq-question {
            padding: 20px 24px;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: 600;
            font-size: 16px;
            user-select: none;
        }

        .faq-question:hover {
            background: #f9f9f9;
        }

        .faq-icon {
            font-size: 20px;
            color: #DB4155;
            transition: transform 0.3s;
        }

        .faq-item.open .faq-icon {
            transform: rotate(45deg);
        }

        .faq-answer {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }

        .faq-item.open .faq-answer {
            max-height: 500px;
        }

        .faq-answer-content {
            padding: 0 24px 20px 24px;
            color: #666;
            line-height: 1.7;
        }

        /* Contact Form */
        .contact-section {
            padding: 80px 0;
            background: #f0f0f0;
        }

        .contact-content {
            max-width: 800px;
            margin: 0 auto;
        }

        .contact-content h2 {
            font-size: 36px;
            margin-bottom: 10px;
        }

        .contact-content h2 span {
            color: #DB4155;
        }

        .contact-content h3 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 30px;
        }

        .contact-form {
            display: grid;
            gap: 20px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group input,
        .form-group textarea {
            padding: 15px;
            border: 1px solid #ddd;
            border-radius: 4px;
            font-size: 16px;
            font-family: inherit;
        }

        .form-group textarea {
            min-height: 150px;
            resize: vertical;
        }

        .submit-btn {
            padding: 15px 40px;
            background: #DB4155;
            color: white;
            border: none;
            border-radius: 25px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            justify-self: start;
        }

        .submit-btn:hover {
            background: #c23648;
        }

        /* Footer */
        footer {
            background: white;
            padding: 60px 0 0;
        }

        .footer-content {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 60px;
            padding-bottom: 40px;
        }

        .footer-column h6 {
            font-size: 22px;
            font-weight: 600;
            margin-bottom: 20px;
            color: #353535;
        }

        .footer-logo {
            max-width: 150px;
            margin-bottom: 15px;
        }

        .footer-tagline {
            font-size: 16px;
            color: #666;
            margin-bottom: 20px;
            line-height: 1.5;
        }

        .social-icons {
            display: flex;
            gap: 15px;
        }

        .social-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            background: rgba(219, 65, 85, 0.1);
            color: #DB4155;
            text-decoration: none;
            transition: all 0.3s;
        }

        .social-icon:hover {
            background: #DB4155;
            color: white;
        }

        .footer-links {
            list-style: none;
        }

        .footer-links li {
            margin-bottom: 10px;
        }

        .footer-links a {
            color: #666;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: color 0.3s;
        }

        .footer-links a:hover {
            color: #DB4155;
        }

        .footer-contact {
            list-style: none;
        }

        .footer-contact li {
            margin-bottom: 10px;
        }

        .footer-contact a {
            color: #666;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.3s;
        }

        .footer-contact a:hover {
            color: #DB4155;
        }

        .footer-bottom {
            background: #DB4155;
            color: white;
            padding: 15px 0;
            text-align: center;
            font-size: 13px;
        }

        /* Responsive */
        @media (max-width: 768px) {
            .hero {
                height: auto;
                min-height: 500px;
            }

            .hero::before {
                background: linear-gradient(100deg, rgba(219, 65, 85, 0.85) 0%, rgba(219, 65, 85, 0.85) 65%, transparent 65%);
            }

            .hero-text {
                max-width: 100%;
                padding: 40px 20px;
            }

            .hero-text h1 {
                font-size: 36px;
            }

            .hero-text p {
                font-size: 16px;
            }

            .welcome-content,
            .feature-grid,
            .tab-content.active,
            .footer-content {
                grid-template-columns: 1fr;
            }

            /* Safety tab: override the 1fr 2fr desktop rule */
            #tab-2.active {
                grid-template-columns: 1fr;
            }

            /* Badge grid inside Safety tab */
            .cert-badges {
                grid-template-columns: 1fr 1fr !important;
                gap: 12px !important;
                margin-bottom: 20px !important;
            }

            .cert-badges > div {
                padding: 20px !important;
            }

            .cert-badges h2 {
                font-size: 48px !important;
            }

            .cert-badges img {
                max-width: 130px !important;
            }

            /* Tab buttons: wrap on mobile */
            .tabs {
                flex-wrap: wrap;
                gap: 4px;
                padding: 0 16px;
            }

            .tab {
                font-size: 11px;
                padding: 10px 14px;
                flex: 1 1 auto;
            }

            /* Tab content padding */
            .tab-content {
                padding: 32px 0;
            }

            .tab-text-box {
                padding: 24px;
            }

            .retailers-grid,
            .faq-grid {
                grid-template-columns: 1fr;
            }

            nav ul {
                flex-wrap: wrap;
                gap: 15px;
            }
        }
    

        
        /* Awesome Innovations Redesign */
        .innovations-redesign {
            background: #ffffff;
        }
        .innovations-main {
            background: #f4f4f4;
            padding: 80px 0 100px 0;
            position: relative;
            overflow: hidden;
        }
        .innovations-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 40px;
            position: relative;
            z-index: 10;
        }
        .innovations-text-wrapper {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .innovations-title h2 {
            font-size: 72px;
            line-height: 1.05;
            font-weight: 900;
            text-transform: uppercase;
            letter-spacing: -0.02em;
            margin: 0;
        }
        .text-solid-red {
            color: #DB4155;
            display: block;
        }
        .text-hollow {
            color: transparent;
            -webkit-text-stroke: 2px #b0b0b0;
            display: block;
        }
        .innovations-desc {
            max-width: 400px;
            padding-top: 15px;
        }
        .innovations-desc p {
            font-size: 20px;
            color: #444;
            font-weight: 500;
            line-height: 1.5;
        }
        .innovations-grill-image {
            position: relative;
            z-index: 5;
            text-align: center;
            margin-top: -100px; /* Pull the grill up behind/around the text slightly */
        }
        .innovations-grill-image img {
            max-width: 1100px;
            width: 100%;
            height: auto;
            display: inline-block;
        }
        .innovations-slider-wrapper {
            max-width: 900px;
            margin: -60px auto 0;
            position: relative;
            z-index: 10;
            padding: 0 60px;
        }
        .innovations-slider-wrapper .miniSwiper {
            width: 100%;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 20px 40px rgba(0,0,0,0.1);
        }
        .miniSwiper .swiper-slide img {
            width: 100%;
            height: auto;
            display: block;
        }
        .mini-prev, .mini-next {
            color: #DB4155 !important;
            --swiper-navigation-size: 32px;
            width: 50px;
            height: 50px;
            background: white;
            border-radius: 50%;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .mini-prev {
            left: 0;
        }
        .mini-next {
            right: 0;
        }
        
        @media (max-width: 1024px) {
            .innovations-title h2 { font-size: 50px; }
            .innovations-grill-image img { max-width: 900px; }
        }
        
        @media (max-width: 768px) {
            .innovations-text-wrapper {
                flex-direction: column;
                text-align: center;
            }
            .innovations-title h2 { font-size: 40px; }
            .innovations-desc { max-width: 100%; margin-top: 20px; }
            .innovations-grill-image { margin-top: 0; }
            .innovations-slider-wrapper { margin-top: 20px; padding: 0 40px; }
            .mini-prev, .mini-next { transform: scale(0.8); }
        }

    </style>
    <script src="/wp-content/uploads/language-redirect.js" defer></script>
    <script src="/wp-content/uploads/shared-header.js" defer></script>

<!-- Language Redirect -->
<script>
    const userLang = navigator.language || navigator.userLanguage;
    const isFrench = userLang.startsWith('fr');
    const isCurrentFrench = window.location.pathname.includes('/fr');
    if (isFrench && !isCurrentFrench) {
        window.location.replace('/fr/');
    } else if (!isFrench && isCurrentFrench) {
        window.location.replace('/');
    }
</script>

<!-- Premium Animations Injection -->
<link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
<style>
    html { scroll-behavior: smooth; }
    body {
        opacity: 0;
        animation: fadeInBody 1.2s ease-in-out forwards;
    }
    @keyframes fadeInBody {
        to { opacity: 1; }
    }
</style>

</head>
<body>
    <header>

    </header>
    <main id="main-content">
        <slot />
    </main>
    <footer class="site-footer">

    </footer>
<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js" defer></script>

    <script>
        // Initialize Swiper (deferred � wait for Swiper library to load)
        window.addEventListener('load', function() {
        const swiper = new Swiper('.mySwiper', {
            slidesPerView: 2,
            spaceBetween: 10,
            loop: true,
            autoplay: {
                delay: 5000,
                disableOnInteraction: false,
            },
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            breakpoints: {
                320: {
                    slidesPerView: 1,
                    spaceBetween: 10
                },
                768: {
                    slidesPerView: 2,
                    spaceBetween: 10
                }
            }
        });
        }); // end window.load

        // Tab Switching
        function switchTab(index) {
            const tabs = document.querySelectorAll('.tab');
            const contents = document.querySelectorAll('.tab-content');
            
            tabs.forEach(tab => tab.classList.remove('active'));
            contents.forEach(content => content.classList.remove('active'));
            
            tabs[index].classList.add('active');
            document.getElementById(`tab-${index}`).classList.add('active');
        }

        // FAQ Toggle
        function toggleFAQ(element) {
            element.classList.toggle('open');
        }

        // Load Retailers
        async function loadRetailers() {
            try {
                
                const querySnapshot = await window.getDocs(window.collection(window.db, "retailers"));
                const retailers = [];
                querySnapshot.forEach((doc) => { retailers.push(doc.data()); });
                retailers.sort((a, b) => (Number(a.display_order) || 0) - (Number(b.display_order) || 0));
                const data = { retailers: retailers };
        
                const container = document.getElementById('retailers-container');
                
                container.innerHTML = data.retailers.map(retailer => {
                    return `
                    <a href="${retailer.url}" target="_blank" rel="noopener" class="retailer-card" aria-label="Buy ${retailer.name} � ${retailer.availability}" style="
                        --card-hover-bg: ${retailer.hover_bg_color || '#DB4155'};
                        --title-color: #333;
                        --availability-color: #DB4155;
                        --button-bg: #DB4155;
                        --button-text: #fff;
                        --star-color: #FFD700;
                    ">
                        <div class="retailer-image-wrap">
                            <img src="${retailer.default_image_url}" alt="${retailer.name}" class="retailer-img-default" loading="lazy" width="600" height="160">
                            <img src="${retailer.hover_image_url}" alt="${retailer.name}" class="retailer-img-hover" loading="lazy" width="600" height="160">
                        </div>
                        <div class="retailer-info">
                            <h3 class="retailer-name">${retailer.name}</h3>
                            <p class="retailer-availability">${retailer.availability}</p>
                            <div class="retailer-btn">BUY NOW</div>
                        </div>
                    </a>
                `}).join('');
            } catch (error) {
                console.error('Error loading retailers:', error);
            }
        }

        // Load FAQs
        async function loadFAQs() {
            try {
                
                const querySnapshot = await window.getDocs(window.collection(window.db, "faqs"));
                const faqs = [];
                querySnapshot.forEach((doc) => {
                    const d = doc.data();
                    if (d.language === 'en') faqs.push(d);
                });
                const data = { faqs: faqs };
        
                const container = document.getElementById('faq-container');
                
                const col1 = data.faqs.slice(0, 6);
                const col2 = data.faqs.slice(6, 12);
                
                container.innerHTML = `
                    <div>
                        ${col1.map(faq => `
                            <div class="faq-item" onclick="toggleFAQ(this)">
                                <div class="faq-question">
                                    <span>${faq.question}</span>
                                    <span class="faq-icon">+</span>
                                </div>
                                <div class="faq-answer">
                                    <div class="faq-answer-content">${faq.answer}</div>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                    <div>
                        ${col2.map(faq => `
                            <div class="faq-item" onclick="toggleFAQ(this)">
                                <div class="faq-question">
                                    <span>${faq.question}</span>
                                    <span class="faq-icon">+</span>
                                </div>
                                <div class="faq-answer">
                                    <div class="faq-answer-content">${faq.answer}</div>
                                </div>
                            </div>
                        `).join('')}
                    </div>
                `;
            } catch (error) {
                console.error('Error loading FAQs:', error);
            }
        }

        // Contact Form � Invisible Turnstile
        let contactFormPending = false;

        function onTurnstileSuccess(token) {
            if (!contactFormPending) return;
            contactFormPending = false;
            submitContactForm(token);
        }

        function onTurnstileError() {
            contactFormPending = false;
            document.getElementById('contact-submit-btn').disabled = false;
            showToast('Security check failed. Please try again.', 'error');
        }

        function onTurnstileExpired() {
            contactFormPending = false;
            if (window.turnstile) window.turnstile.reset('#cf-turnstile-contact');
        }

        document.getElementById('contact-form').addEventListener('submit', function(e) {
            e.preventDefault();
            const btn = document.getElementById('contact-submit-btn');
            const token = document.querySelector('[name="cf-turnstile-response"]')?.value;
            if (!token) {
                showToast('Please wait for the security check to complete.', 'error');
                return;
            }
            btn.disabled = true;
            submitContactForm(token);
        });

        async function submitContactForm(token) {
            const btn = document.getElementById('contact-submit-btn');
            const form = document.getElementById('contact-form');
            const rawData = Object.fromEntries(new FormData(form));
            const data = {
                first_name: rawData.firstName,
                last_name: rawData.lastName,
                email: rawData.email,
                message: rawData.message,
                turnstile_token: token || ''
            };
            try {
                
                data.timestamp = new Date().toISOString();
                await window.addDoc(window.collection(window.db, "contact_messages"), data);
                const response = { ok: true };
        
                if (response.ok) {
                    showToast('Thank you! Your message has been sent.', 'success');
                    form.reset();
                    if (window.turnstile) window.turnstile.reset();
                } else {
                    const err = await response.json();
                    showToast(err.error || 'Error sending message. Please try again.', 'error');
                    if (window.turnstile) window.turnstile.reset();
                }
            } catch (error) {
                console.error('Error:', error);
                showToast('Error sending message. Please try again.', 'error');
            } finally {
                btn.disabled = false;
            }
        }

        // Toast notification function
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                background: white;
                padding: 16px 24px;
                border-radius: 8px;
                box-shadow: 0 4px 16px rgba(0,0,0,0.15);
                display: flex;
                align-items: center;
                gap: 12px;
                z-index: 10000;
                animation: slideIn 0.3s ease;
                border-left: 4px solid ${type === 'success' ? '#27ae60' : type === 'error' ? '#e74c3c' : '#3498db'};
            `;
            
            const icon = type === 'success' ? '?' : type === 'error' ? '?' : '?';
            const color = type === 'success' ? '#27ae60' : type === 'error' ? '#e74c3c' : '#3498db';
            
            toast.innerHTML = `
                <span style="color: ${color}; font-size: 20px; font-weight: bold;">${icon}</span>
                <span style="color: #2c3e50; font-weight: 500;">${message}</span>
            `;
            
            document.body.appendChild(toast);
            
            setTimeout(() => {
                toast.style.animation = 'slideOut 0.3s ease';
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }

        // Add toast animations
        const style = document.createElement('style');
        style.textContent = `
            @keyframes slideIn {
                from { transform: translateX(400px); opacity: 0; }
                to { transform: translateX(0); opacity: 1; }
            }
            @keyframes slideOut {
                from { transform: translateX(0); opacity: 1; }
                to { transform: translateX(400px); opacity: 0; }
            }
        `;
        document.head.appendChild(style);

        // Skeleton HTML � injected immediately to reserve grid space (eliminates CLS)
        const skeletonCard = `<div class="retailer-skeleton">
            <div class="retailer-skeleton-img"></div>
            <div class="retailer-skeleton-line"></div>
            <div class="retailer-skeleton-line short"></div>
            <div class="retailer-skeleton-btn"></div>
        </div>`;

        // Load dynamic content on page load
        document.addEventListener('DOMContentLoaded', () => {
            
        });

        // Smooth scrolling for anchor links
        document.querySelectorAll('a[href^="#"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                }
            });
        });
    </script>
<script src="/wp-content/uploads/shared-footer.js" is:inline></script>

<!-- Premium Animations Injection JS -->
<script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
<script>
    document.addEventListener('DOMContentLoaded', () => {
        const containers = document.querySelectorAll('.welcome, .product-features, .feature-content, .feature-image, .feature-video, .image-carousel, .retailers, .faq, .contact');
        containers.forEach(container => {
            if(!container.hasAttribute('data-aos')) {
                container.setAttribute('data-aos', 'fade-up');
            }
        });
        AOS.init({ once: true, offset: 50, duration: 1500, easing: 'ease-out-cubic' });
    });
</script>


</body>
</html>
