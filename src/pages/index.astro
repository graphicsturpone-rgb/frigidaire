---
import Layout from '../layouts/Layout.astro';
import homeContent from '../content/pages/home.json';

// Fetch retailer and FAQ data from API at BUILD TIME (server-side, no CORS)
let apiRetailers = [];
let apiFaqs = [];
try {
    const [retRes, faqRes] = await Promise.all([
        fetch('https://frigidaire-api.franco-p.workers.dev/api/retailers'),
        fetch('https://frigidaire-api.franco-p.workers.dev/api/faqs?lang=en'),
    ]);
    const retData = await retRes.json();
    const faqData = await faqRes.json();
    apiRetailers = retData.retailers || [];
    apiFaqs = faqData.faqs || [];
} catch (e) {
    console.warn('Failed to fetch from API at build time:', e);
}
---
<Layout title="Frigidaire Outdoor Living - Electric Dual Element Grill" lang="en">


    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content container">
            <div class="hero-text">
                <h1>{homeContent.hero_title_en}</h1>
                <p>{homeContent.hero_subtitle_en}</p>
                <a href="/home-page/freestanding-folding-electric-dual-element-grill-guide-overview/" class="btn" aria-label="Learn more about the Frigidaire Dual Element Electric Grill">{homeContent.hero_btn_text_en}</a>
            </div>
        </div>
    </section>

<!-- Welcome Section Redesign (Inline) -->
    <!-- Welcome Section (Tailwind CSS) -->
    <section class="bg-white py-20 px-5 md:px-10">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center">
            <div class="flex flex-col">
                <h2 class="text-4xl md:text-5xl font-extrabold text-[#333] leading-[1.1] uppercase font-['Gotham',sans-serif]">
                    WELCOME<br/>
                    TO FRIGIDAIRE<br/>
                    <span class="text-[#DB4155]">OUTDOOR LIVING</span>
                </h2>
            </div>
            <div class="flex flex-col gap-4">
                <h3 class="text-2xl font-bold text-[#333] font-['Gotham',sans-serif]">
                    Where innovation meets the open air.
                </h3>
                <p class="text-[#666] text-base leading-relaxed font-['Gotham',sans-serif]">
                    Building on over 100 years of trusted performance, Frigidaire is stepping outside &mdash; creating durable, high-performance outdoor solutions designed for effortless living.
                </p>
            </div>
        </div>
    </section>

<!-- Product Features Section (Tailwind CSS) -->
    <section class="bg-[#F1F1F1] pt-20" id="product">
        <div class="text-center mb-10">
            <div class="bg-[#DB4155] text-white py-4 px-8 inline-block text-lg font-semibold uppercase tracking-widest">
