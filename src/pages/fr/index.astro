---
import Layout from '../../layouts/Layout.astro';
import homeContent from '../../content/pages/home.json';
import { getCollection } from 'astro:content';

const retailers = await getCollection('retailers');
retailers.sort((a, b) => a.data.display_order - b.data.display_order);

const faqs = await getCollection('faqs', ({ data }) => {
  return data.language === 'fr';
});
---
<Layout title="Frigidaire Outdoor Living - Gril électrique à double élément" lang="fr">


    <!-- Hero Section -->
    <section class="hero" id="home">
        <div class="hero-content container">
            <div class="hero-text">
                <h1>{homeContent.hero_title_fr}</h1>
                <p>{homeContent.hero_subtitle_fr}</p>
                <a aria-label="En savoir plus sur le gril électrique à double élément Frigidaire" href="/fr/accueil/apercu-du-produit/" class="btn">{homeContent.hero_btn_text_fr}</a>
            </div>
        </div>
    </section>

<!-- Welcome Section Redesign (Inline) -->
    <!-- Welcome Section (Tailwind CSS) -->
    <section class="bg-white py-20 px-5 md:px-10">
        <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-20 items-center">
            <div class="flex flex-col">
                <h2 class="text-4xl md:text-5xl font-extrabold text-[#333] leading-[1.1] uppercase font-['Gotham',sans-serif]">
                    WELCOME<br/>
                    TO FRIGIDAIRE<br/>
                    <span class="text-[#DB4155]">OUTDOOR LIVING</span>
                </h2>
            </div>
            <div class="flex flex-col gap-4">
                <h3 class="text-2xl font-bold text-[#333] font-['Gotham',sans-serif]">
                    L'o&#249; l'innovation rencontre le plein air.
                </h3>
                <p class="text-[#666] text-base leading-relaxed font-['Gotham',sans-serif]">
                    Avec plus de 100 ans de performance reconnue, Frigidaire sort &#224; l'ext&#233;rieur &mdash; en cr&#233;ant des solutions ext&#233;rieures durables et hautement performantes, con&#231;ues pour une vie sans effort.
                </p>
            </div>
        </div>
    </section>

<!-- Product Features Section (Tailwind CSS) -->
    <section class="bg-white pt-20" id="product">
        <div class="text-center">
            <div class="bg-[#DB4155] text-white py-4 px-8 block w-full text-lg font-semibold uppercase tracking-widest">
                D&#201;COUVREZ NOS INNOVATIONS POUR LA FAMILLE
            </div>
        </div>
        <div class="w-full text-center">
            <video autoplay loop muted playsinline class="w-full h-auto block">
                <source src="https://media.frigidaireoutdoorliving.com/ENG-LAST-FEATURES-VID.mp4" type="video/mp4">
                Your browser does not support the video tag.
            </video>
        </div>
    </section>


    <!-- Image Carousel (Tailwind CSS) -->
    <section class="bg-white py-16">
        <div class="relative max-w-7xl mx-auto px-10 md:px-16">
            <div class="swiper mySwiper w-full h-full">
                <div class="swiper-wrapper">
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/OPEN-GRILL-COOKING-FOOD-1.webp" alt="Open Grill Cooking Food" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/ELEC-Grill-PROFILE-FrontFace.webp" alt="Grill Front Face" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/GRILL-OPNER-CLOSEUP-1.webp" alt="Grill Opener Closeup" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/ELEC-Grill-PROFILE-45d-TopLeft.webp" alt="Grill 45 Degree View" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/OPEN-HEATED-GRILL-1.webp" alt="Open Heated Grill" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                    <div class="swiper-slide flex justify-center items-center text-center">
                        <img src="/wp-content/uploads/2026/01/ELEC-Grill-PROFILE-BackFace.webp" alt="Grill Back Face" loading="lazy" width="1200" height="800" class="w-full h-auto object-cover">
                    </div>
                </div>
                <div class="swiper-button-prev !text-[#DB4155] after:!text-2xl after:!font-bold"></div>
                <div class="swiper-button-next !text-[#DB4155] after:!text-2xl after:!font-bold"></div>
            </div>
        </div>
    </section>


<!-- Getting Started Tabs (Tailwind CSS) -->
    <section class="bg-white">
        <!-- Header -->
        <div class="bg-[#DB4155] text-white py-4 px-8 text-center text-lg font-semibold uppercase tracking-widest">
            POUR COMMENCER AVEC VOTRE BARBECUE
        </div>
        
        <!-- Tabs -->
        <div class="flex flex-wrap justify-center gap-2 md:gap-16 py-8 px-4 bg-white">
            <button class="tab-btn active text-sm md:text-base font-semibold text-[#666] border-b-4 border-transparent uppercase pb-2 transition-all duration-300" data-target="tab-0">À PROPOS DU BARBECUE</button>
            <button class="tab-btn text-sm md:text-base font-semibold text-[#666] border-b-4 border-transparent uppercase pb-2 transition-all duration-300" data-target="tab-1">QU'Y A-T-IL DANS LA BOÎTE ?</button>
            <button class="tab-btn text-sm md:text-base font-semibold text-[#666] border-b-4 border-transparent uppercase pb-2 transition-all duration-300" data-target="tab-2">SÉCURITÉ ET CERTIFICATION</button>
        </div>

        <!-- Tab Contents -->
        <div class="max-w-7xl mx-auto px-5 md:px-10 pb-20">
            
            <!-- Tab 0: ABOUT THE GRILL -->
            <div class="tab-pane active grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center" id="tab-0">
                <div class="text-center">
                    <img src="https://frigidaireoutdoorliving.com/wp-content/uploads/2026/01/DUAL-ELEC-GRILL-DIMENTIONS-1-scaled.webp" alt="Grill Specifications with Dimensions" loading="lazy" width="1200" height="849" class="w-full h-auto object-cover" />
                </div>
                <div class="bg-[#f5f5f5] p-8 md:p-10 rounded-lg">
                    <h3 class="text-2xl md:text-3xl font-bold text-[#333] mb-6 uppercase leading-tight font-['Gotham',sans-serif]">LES DOUBLES ÉLÉMENTS CHAUFFANTS HAUTE PERFORMANCE <span class="text-[#DB4155]">ATTEIGNENT JUSQU'À 700&deg;F</span></h3>
                    <ul class="space-y-3">
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Grande surface de cuisson en fonte de 19" x 17" avec grille de réchaud intégrée.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Chauffe en seulement 20 minutes et comprend deux sondes à viande pour un contrôle précis de la température.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Des tablettes latérales pivotantes offrent un espace de préparation et de service pratique.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Construction résistante à l'eau IPX4 avec certification UL pour une utilisation extérieure sécuritaire.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Alimentation électrique 1750W / 120V couverte par une garantie constructeur de deux ans.</li>
                    </ul>
                </div>
            </div>

            <!-- Tab 1: WHAT'S IN THE BOX -->
            <div class="tab-pane hidden grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16 items-center" id="tab-1">
                <div class="bg-[#f5f5f5] p-8 md:p-10 rounded-lg">
                    <h3 class="text-2xl md:text-3xl font-bold text-[#333] mb-6 uppercase leading-tight font-['Gotham',sans-serif]">TOUT CE DONT VOUS AVEZ BESOIN POUR COMMENCER <span class="text-[#DB4155]">DÈS LA SORTIE DE LA BOÎTE</span></h3>
                    <ul class="space-y-3">
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Barbecue électrique assemblé avec bac à graisse intégré.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Support de base avec décapsuleur et support de cordon d'alimentation.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Tablettes latérales et roues pour plus d'espace de travail et de mobilité.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Sondes de température à viande pour un contrôle précis de la cuisson.</li>
                    </ul>
                </div>
                <div class="relative bg-[#DB4155] p-10" style="clip-path: polygon(20% 0, 100% 0, 100% 100%, 0 100%);">
                    <img src="/wp-content/uploads/2026/01/BOX-1-1024x645.webp" alt="Box Contents" loading="lazy" width="1024" height="645" class="w-full h-auto block" />
                </div>
            </div>

            <!-- Tab 2: SAFETY & CERTIFICATION -->
            <div class="tab-pane hidden grid grid-cols-1 md:grid-cols-[1fr_2fr] gap-10 md:gap-16 items-start" id="tab-2">
                <div class="bg-[#f5f5f5] p-8 md:p-10 rounded-lg">
                    <h3 class="text-2xl md:text-3xl font-bold text-[#333] mb-6 uppercase leading-tight font-['Gotham',sans-serif]"><span class="text-[#DB4155]">ATTENTION :</span> RISQUE DE CHOC ÉLECTRIQUE</h3>
                    <ul class="space-y-3 mb-6">
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Gardez la connexion de la rallonge au sec et hors du sol.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Pour garantir une protection continue contre les risques de chocs électriques, connectez uniquement à des prises correctement mises à la terre.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Usage domestique uniquement.</li>
                        <li class="relative pl-6 text-[#666] text-base leading-relaxed before:content-['▸'] before:absolute before:left-0 before:text-[#DB4155] before:font-bold">Ne pas plonger dans l'eau.</li>
                    </ul>
                    <a href="/wp-content/uploads/2025/12/MANUAL-TEG-003-C-FRIGIDAIRE-FREE-STANDING-FOLDING-ELECTRIC-DUAL-ELEMENT-GRILL.pdf" target="_blank" class="inline-block bg-[#ccc] text-[#333] font-semibold py-3 px-6 rounded-full transition-colors hover:bg-gray-300">LIRE LE MANUEL AVANT UTILISATION &rarr;</a>
                </div>
                <div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-8">
                        <div class="bg-[#f5f5f5] p-10 text-center rounded-lg flex items-center justify-center">
                            <img src="/wp-content/uploads/2025/12/FRI-LISTED-300x180.webp" alt="UL Listed" loading="lazy" width="300" height="180" class="max-w-[200px]" />
                        </div>
                        <div class="bg-[#f5f5f5] p-10 text-center rounded-lg flex items-center justify-center">
                            <h2 class="text-[#DB4155] text-5xl md:text-7xl font-bold m-0 font-['Gotham',sans-serif]">IPX4</h2>
                        </div>
                    </div>
                    <div class="text-left text-[#666] font-['Gotham',sans-serif]">
                        <p class="mb-6 leading-relaxed">Ce barbecue Frigidaire Outdoor Living est certifié UL pour les États-Unis et le Canada, garantissant qu'il répond aux normes de sécurité strictes. Il est également classé IPX4 pour sa résistance aux intempéries, offrant une protection fiable contre les éclaboussures d'eau pour une utilisation extérieure en toute sécurité.</p>
                        <a href="/wp-content/uploads/2025/12/MANUAL-TEG-003-C-FRIGIDAIRE-FREE-STANDING-FOLDING-ELECTRIC-DUAL-ELEMENT-GRILL.pdf" download class="inline-block bg-[#DB4155] text-white font-semibold py-3 px-6 rounded-full transition-colors hover:bg-[#c23648]">TÉLÉCHARGER LE MANUEL</a>
                    </div>
                </div>
            </div>

        </div>
    </section>

    <!-- Tailwind JS Tab Script -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const tabs = document.querySelectorAll('.tab-btn');
            const panes = document.querySelectorAll('.tab-pane');
            
            tabs.forEach(tab => {
                tab.addEventListener('click', () => {
                    // Remove active from all tabs
                    tabs.forEach(t => {
                        t.classList.remove('active', 'border-[#DB4155]', 'text-[#DB4155]');
                        t.classList.add('border-transparent', 'text-[#666]');
                    });
                    
                    // Add active to clicked
                    tab.classList.remove('border-transparent', 'text-[#666]');
                    tab.classList.add('active', 'border-[#DB4155]', 'text-[#DB4155]');
                    
                    // Hide all panes
                    panes.forEach(pane => {
                        pane.classList.add('hidden');
                    });
                    
                    // Show target pane
                    const target = document.getElementById(tab.getAttribute('data-target'));
                    if(target) {
                        target.classList.remove('hidden');
                    }
                });
            });
            
            // Set initial active state correctly based on HTML classes
            const initialActiveTab = document.querySelector('.tab-btn.active');
            if (initialActiveTab) {
                initialActiveTab.classList.remove('border-transparent', 'text-[#666]');
                initialActiveTab.classList.add('border-[#DB4155]', 'text-[#DB4155]');
            }
        });
    </script>

<!-- Where to Buy (JS-loaded from API) -->
    <section class="bg-white py-20" id="where-to-buy">
        <div class="max-w-7xl mx-auto px-5 md:px-10 text-left">
            <h2 class="text-3xl md:text-4xl font-extrabold text-[#333] mb-2 uppercase font-['Gotham',sans-serif]">
                <span class="text-[#DB4155]">DISPONIBLE</span> CHEZ
            </h2>
            <h3 class="text-2xl md:text-3xl font-bold text-[#333] mb-12 uppercase font-['Gotham',sans-serif]">
                NOS DÉTAILLANTS DE CONFIANCE
            </h3>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="retailers-grid">
                <!-- Cards injected by JS -->
            </div>
        </div>
    </section>

    <script>
        async function loadRetailers() {
            try {
                const res = await fetch('https://frigidaire-api.franco-p.workers.dev/api/retailers');
                const data = await res.json();
                const grid = document.getElementById('retailers-grid');
                if (!grid) return;

                grid.innerHTML = data.retailers.map(r => {
                    const availability = r.availability_fr || r.availability;
                    const isWhite = (r.hover_bg_color || '').toLowerCase() === '#fff' || (r.hover_bg_color || '').toLowerCase() === '#ffffff';

                    return `
                        <a href="${r.url}" target="_blank" rel="noopener" aria-label="Acheter ${r.name} - ${availability}"
                           class="group flex flex-col rounded-xl overflow-hidden bg-[#f5f5f5] cursor-pointer transition-colors duration-300"
                           style="--hover-bg: ${r.hover_bg_color || '#DB4155'};">

                            <div class="relative w-full bg-white overflow-hidden" style="aspect-ratio:2/1;">
                                <img src="${r.default_image_url}" alt="${r.name}"
                                     class="absolute inset-0 w-full h-full object-cover transition-opacity duration-300 group-img-default"
                                     loading="lazy" />
                                <img src="${r.hover_image_url}" alt="${r.name}"
                                     class="absolute inset-0 w-full h-full object-contain p-8 opacity-0 transition-opacity duration-300 group-img-hover"
                                     loading="lazy" />
                            </div>

                            <div class="flex flex-col flex-grow p-8 transition-opacity duration-300 group-text">
                                <h3 class="text-3xl font-extrabold text-[#333] mb-1" style="font-family:'Gotham',sans-serif;">${r.name}</h3>
                                <p class="text-[#DB4155] text-sm font-medium mb-8 flex-grow">${availability}</p>
                                <div class="w-full py-3 rounded-full text-center font-bold text-sm tracking-wide border-2 bg-[#DB4155] border-[#DB4155] text-white transition-all duration-300 retailer-btn">ACHETER</div>
                            </div>
                        </a>
                    `;
                }).join('');

                grid.querySelectorAll('a').forEach(card => {
                    const hoverBg = card.style.getPropertyValue('--hover-bg');
                    const imgDefault = card.querySelector('.group-img-default');
                    const imgHover = card.querySelector('.group-img-hover');
                    const text = card.querySelector('.group-text');
                    const btn = card.querySelector('.retailer-btn');
                    const imgWrap = card.querySelector('[style*="aspect-ratio"]');

                    card.addEventListener('mouseenter', () => {
                        card.style.backgroundColor = hoverBg;
                        if (imgWrap) imgWrap.style.backgroundColor = hoverBg;
                        if (imgDefault) imgDefault.style.opacity = '0';
                        if (imgHover) imgHover.style.opacity = '1';
                        if (text) text.style.opacity = '0';
                        if (btn) {
                            btn.style.background = 'transparent';
                            btn.style.color = hoverBg.toLowerCase() === '#fff' || hoverBg.toLowerCase() === '#ffffff' ? '#DB4155' : 'white';
                            btn.style.borderColor = hoverBg.toLowerCase() === '#fff' || hoverBg.toLowerCase() === '#ffffff' ? '#DB4155' : 'white';
                        }
                    });
                    card.addEventListener('mouseleave', () => {
                        card.style.backgroundColor = '';
                        if (imgWrap) imgWrap.style.backgroundColor = 'white';
                        if (imgDefault) imgDefault.style.opacity = '1';
                        if (imgHover) imgHover.style.opacity = '0';
                        if (text) text.style.opacity = '1';
                        if (btn) {
                            btn.style.background = '#DB4155';
                            btn.style.color = 'white';
                            btn.style.borderColor = '#DB4155';
                        }
                    });
                });

            } catch (e) {
                console.error('Failed to load retailers:', e);
            }
        }
        document.addEventListener('DOMContentLoaded', loadRetailers);
    </script>

    <!-- FAQ Section (Tailwind CSS) -->
    <section class="bg-[#f9f9f9] py-20" id="faq">
        <div class="max-w-7xl mx-auto px-5 md:px-10">
            <h2 class="text-3xl md:text-4xl font-extrabold text-[#333] mb-2 uppercase font-['Gotham',sans-serif]">FOIRE AUX</h2>
            <h3 class="text-2xl md:text-3xl font-bold text-[#333] mb-12 uppercase font-['Gotham',sans-serif]">QUESTIONS <span class="text-[#DB4155]">FRÉQUENTES</span></h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-0" id="faq-grid">
                <!-- FAQs injected by JS -->
            </div>
        </div>
    </section>

    <script>
        async function loadFAQs() {
            try {
                const res = await fetch('https://frigidaire-api.franco-p.workers.dev/api/faqs?lang=fr');
                const data = await res.json();
                const grid = document.getElementById('faq-grid');
                if (!grid || !data.faqs) return;
                const col1 = data.faqs.slice(0, 6);
                const col2 = data.faqs.slice(6, 12);
                const renderFAQs = (faqs) => faqs.map(faq => `
                    <div class="faq-item border-b border-gray-200 py-5 cursor-pointer">
                        <div class="flex justify-between items-center gap-4">
                            <span class="text-[#333] font-semibold text-base leading-snug">${faq.question}</span>
                            <span class="faq-icon text-[#DB4155] text-2xl font-bold leading-none flex-shrink-0">+</span>
                        </div>
                        <div class="faq-answer max-h-0 overflow-hidden transition-all duration-500">
                            <div class="pt-3 text-[#666] text-sm leading-relaxed">${faq.answer}</div>
                        </div>
                    </div>
                `).join('');
                grid.innerHTML = `<div>${renderFAQs(col1)}</div><div>${renderFAQs(col2)}</div>`;
                document.querySelectorAll('.faq-item').forEach(item => {
                    item.addEventListener('click', () => {
                        const answer = item.querySelector('.faq-answer');
                        const icon = item.querySelector('.faq-icon');
                        const isOpen = item.classList.contains('faq-open');
                        item.classList.toggle('faq-open');
                        if (!isOpen) {
                            answer.style.maxHeight = answer.scrollHeight + 'px';
                            icon.textContent = '×';
                        } else {
                            answer.style.maxHeight = '0';
                            icon.textContent = '+';
                        }
                    });
                });
            } catch (e) { console.error('Failed to load FAQs:', e); }
        }
        document.addEventListener('DOMContentLoaded', loadFAQs);
    </script>

    <!-- Contact Form (Tailwind CSS) -->
    <section class="bg-white py-20" id="contact">
        <div class="max-w-7xl mx-auto px-5 md:px-10">
            <div class="max-w-xl mx-auto text-center">
                <h2 class="text-3xl md:text-4xl font-extrabold text-[#333] mb-2 uppercase font-['Gotham',sans-serif]">VOUS AVEZ <span class="text-[#DB4155]">D'AUTRES QUESTIONS?</span></h2>
                <h3 class="text-2xl font-bold text-[#333] mb-10 font-['Gotham',sans-serif]">Remplissez le formulaire.</h3>
                <form id="contact-form" class="flex flex-col gap-4">
                    <input type="text" name="firstName" placeholder="Prénom" required class="w-full border border-gray-300 rounded px-4 py-3 text-[#333] text-sm outline-none focus:border-[#DB4155] transition-colors" />
                    <input type="text" name="lastName" placeholder="Nom de famille" required class="w-full border border-gray-300 rounded px-4 py-3 text-[#333] text-sm outline-none focus:border-[#DB4155] transition-colors" />
                    <input type="email" name="email" placeholder="E-mail" required class="w-full border border-gray-300 rounded px-4 py-3 text-[#333] text-sm outline-none focus:border-[#DB4155] transition-colors" />
                    <textarea name="message" placeholder="Votre message" rows="5" required class="w-full border border-gray-300 rounded px-4 py-3 text-[#333] text-sm outline-none focus:border-[#DB4155] transition-colors resize-none"></textarea>
                    <div id="cf-turnstile-contact" class="cf-turnstile" data-sitekey="0x4AAAAAADJQp0TJa6LotiLr" data-callback="onTurnstileSuccess" data-error-callback="onTurnstileError" data-expired-callback="onTurnstileExpired"></div>
                    <script is:inline>
                        (function() {
                            var host = window.location.hostname;
                            var el = document.getElementById('cf-turnstile-contact');
                            if (el && host !== 'frigidaireoutdoorliving.com' && host !== 'www.frigidaireoutdoorliving.com') {
                                el.setAttribute('data-sitekey', '1x00000000000000000000AA');
                            }
                        })();
                    </script>
                    <button type="submit" id="contact-submit-btn" class="w-48 bg-[#DB4155] text-white font-bold py-3 px-6 rounded-full uppercase text-sm tracking-wide hover:bg-[#c23648] transition-colors">ENVOYER LE MESSAGE</button>
                </form>
            </div>
